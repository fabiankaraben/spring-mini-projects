<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>oauth2-authorization-server</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>oauth2-authorization-server</name>
	<description>
		Spring Boot mini-project implementing a fully customized OAuth2 Authorization Server
		using Spring Authorization Server. Demonstrates client_credentials and authorization_code
		flows, custom JWT claims enrichment (roles, tenant, metadata), RSA key pair signing,
		and a complete token introspection endpoint. Includes JUnit 5 unit tests for domain
		logic and full integration tests backed by Testcontainers (PostgreSQL for client
		persistence, WireMock for token introspection verification).
	</description>

	<properties>
		<java.version>21</java.version>
		<!-- Testcontainers BOM version — pins all Testcontainers module versions in sync -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>

	<dependencies>

		<!--
			Spring Authorization Server:
			The core dependency that provides the OAuth2 Authorization Server.
			It builds on top of Spring Security and provides:
			  - Authorization endpoints (/oauth2/authorize, /oauth2/token, /oauth2/jwks,
			    /oauth2/introspect, /oauth2/revoke)
			  - OAuth2 grant type handlers (authorization_code, client_credentials,
			    refresh_token)
			  - JWT token generation with RSA signing (JWK Set endpoint)
			  - RegisteredClient persistence (in-memory or JDBC)
			  - OAuth2AuthorizationService for token storage
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-oauth2-authorization-server</artifactId>
		</dependency>

		<!--
			Spring Web (MVC):
			Provides the DispatcherServlet, REST controllers, and Jackson JSON support.
			Used for the custom management endpoints (/auth/clients, /auth/status).
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!--
			Spring Data JPA:
			ORM layer used to persist RegisteredClient entries via the
			JdbcRegisteredClientRepository. Hibernate is the JPA provider.
			This allows client registrations to survive server restarts.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>

		<!--
			Bean Validation (Hibernate Validator):
			Provides @NotBlank, @Size, @NotNull etc. on DTO objects.
			Used to validate client registration requests at the controller layer.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!--
			Spring Boot Actuator:
			Exposes management endpoints such as /actuator/health and /actuator/info.
			Useful for monitoring the authorization server in production.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!--
			PostgreSQL JDBC Driver:
			Runtime-only dependency. The JDBC driver is loaded by the JVM at startup
			via the java.sql.Driver SPI. It is not needed at compile time because we
			code against the standard javax.sql.DataSource abstraction.
		-->
		<dependency>
			<groupId>org.postgresql</groupId>
			<artifactId>postgresql</artifactId>
			<scope>runtime</scope>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!--
			Spring Boot Test:
			Pulls in JUnit 5, AssertJ, Mockito, MockMvc and all Spring test
			infrastructure needed for unit and integration tests.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Spring Security Test:
			Provides SecurityMockMvcRequestPostProcessors and test utilities for
			simulating authenticated requests in Spring MVC tests.
		-->
		<dependency>
			<groupId>org.springframework.security</groupId>
			<artifactId>spring-security-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers JUnit 5 integration:
			Provides @Testcontainers class-level annotation and @Container field
			annotation that manage Docker container lifecycle alongside JUnit 5.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers PostgreSQL module:
			Provides PostgreSQLContainer — a real Postgres Docker container for
			integration tests. The authorization server stores OAuth2 clients and
			tokens in PostgreSQL, so tests need a live database.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>postgresql</artifactId>
			<scope>test</scope>
		</dependency>

	</dependencies>

	<!--
		Manage all Testcontainers module versions through the BOM (Bill of Materials).
		This ensures all testcontainers-* artefacts resolve to a compatible version set.
	-->
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin: packages the application as an executable fat-jar -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>

			<!--
				Maven Surefire Plugin: configures test execution for Java 21+.

				argLine breakdown:
				  -XX:+EnableDynamicAgentLoading  — silences Mockito/ByteBuddy agent warnings
				  -Xshare:off                     — disables class-data sharing (avoids conflicts)
				  -Dnet.bytebuddy.experimental    — required on Java 25+; harmless on Java 21-24
				  add-opens                       — grants ByteBuddy/Mockito deep reflection access

				DOCKER_API_VERSION=1.44:
				  Docker Desktop 29+ rejects the legacy v1.24 API path that docker-java uses by
				  default. Setting 1.44 here (and in docker-java.properties on the test classpath)
				  ensures Testcontainers works correctly on Docker Desktop 29+.
			-->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Ensures docker-java uses API v1.44 (Docker Desktop 29+ requires this) -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>

</project>
