<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.4.3</version>
        <relativePath/> <!-- lookup parent from repository -->
    </parent>
    <groupId>com.example</groupId>
    <artifactId>mustache-templates</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <name>mustache-templates</name>
    <description>Mustache Templates mini-project: rendering dynamic HTML pages using Mustache templates</description>
    <properties>
        <java.version>21</java.version>
    </properties>
    <dependencies>

        <!--
            Spring Boot Web Starter: includes Spring MVC, embedded Tomcat,
            Jackson for JSON, and all the wiring needed for @Controller endpoints.
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!--
            Mustache Starter: integrates the JMustache template engine with
            Spring MVC. Mustache processes .mustache template files stored
            under src/main/resources/templates/, expanding {{variable}}
            expressions, {{#section}}...{{/section}} blocks, and
            {{^inverted}}...{{/inverted}} (falsy) blocks at render time.

            Key Mustache concepts:
              - {{variable}}            : outputs a value (HTML-escaped by default)
              - {{{variable}}}          : outputs raw (unescaped) HTML
              - {{#list}}...{{/list}}   : iterates over a non-empty list (section)
              - {{^list}}...{{/list}}   : renders when the list is empty or false
              - {{#flag}}...{{/flag}}   : conditional block (truthy section)
              - {{^flag}}...{{/flag}}   : conditional block (falsy / inverted section)
              - {{.}}                   : refers to the current item in a loop
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-mustache</artifactId>
        </dependency>

        <!--
            Testing: JUnit 5, Mockito, MockMvc, and Spring Boot Test utilities.
            spring-boot-starter-test transitively brings:
              - JUnit 5 (jupiter)
              - Mockito
              - Spring MockMvc
              - AssertJ
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <!-- Maven Surefire Plugin: discovers and runs unit/integration tests -->
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <!-- Required for Mockito byte-buddy on Java 21 -->
                    <argLine>-Dnet.bytebuddy.experimental=true</argLine>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
