<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>distributed-tracing-sleuth</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>distributed-tracing-sleuth</name>
	<description>Spring Boot mini-project demonstrating distributed tracing with Micrometer Tracing (the successor to Spring Cloud Sleuth). Generates trace IDs and span IDs, propagates them across simulated service calls, exports traces to Zipkin, and exposes Actuator endpoints for observability.</description>

	<properties>
		<java.version>21</java.version>
		<!-- Testcontainers BOM - keeps all testcontainers module versions in sync -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>

	<dependencies>

		<!--
			Spring Boot Web (Servlet / Tomcat):
			Provides the embedded Tomcat server and Spring MVC for building
			traditional blocking REST controllers. This project intentionally uses
			the servlet stack (not WebFlux) to show that Micrometer Tracing works
			equally well in both threading models.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!--
			Spring Boot Actuator:
			Exposes management endpoints including /actuator/health, /actuator/info,
			and - critically - /actuator/metrics which publishes all Micrometer metrics
			including trace and span counters. The /actuator/health endpoint includes
			liveness/readiness probes suitable for Docker health checks.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!--
			Micrometer Tracing Bridge - Brave backend:
			Micrometer Tracing is the Spring Boot 3 successor to Spring Cloud Sleuth.
			It provides a vendor-neutral API (io.micrometer.tracing.*) that application
			code uses directly.

			The "brave" bridge wires Micrometer's tracing API to the Brave/Zipkin
			implementation underneath. Brave is the tracer that actually creates and
			manages Span objects and propagates W3C Trace Context headers (traceparent,
			tracestate) or B3 headers between HTTP requests.

			Without this bridge, Micrometer Tracing is a no-op - traces are not created.
		-->
		<dependency>
			<groupId>io.micrometer</groupId>
			<artifactId>micrometer-tracing-bridge-brave</artifactId>
		</dependency>

		<!--
			Zipkin Reporter - Brave:
			Sends completed Spans to a Zipkin server over HTTP.
			Spans are buffered in memory and flushed asynchronously in batches,
			keeping request latency unaffected by trace export.

			The reporter reads spring.zipkin.base-url from application properties
			to find the Zipkin endpoint. In Docker Compose the Zipkin container
			is reachable by service name (http://zipkin:9411).
		-->
		<dependency>
			<groupId>io.zipkin.reporter2</groupId>
			<artifactId>zipkin-reporter-brave</artifactId>
		</dependency>

		<!--
			Micrometer Observation - Spring Web MVC integration:
			Automatically instruments every incoming HTTP request handled by Spring MVC
			DispatcherServlet. For each request it creates an Observation (which
			produces a Span under the hood) named "http.server.requests".

			This is what propagates the incoming traceparent / B3 header so that
			an inbound trace ID is reused instead of generating a new root span.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-aop</artifactId>
		</dependency>

		<!--
			Spring Boot Validation:
			Provides Bean Validation (JSR-380) via Hibernate Validator.
			Used to validate request bodies and path variables in controllers.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!--
			Feign Client (Spring Cloud OpenFeign):
			A declarative HTTP client that Spring Boot auto-configures.
			Used here to simulate an inter-service call from the OrderService
			to the InventoryService, demonstrating automatic trace-context
			propagation across HTTP hops via the B3/W3C headers injected by
			Brave's HttpClientParser.
		-->
		<dependency>
			<groupId>org.springframework.cloud</groupId>
			<artifactId>spring-cloud-starter-openfeign</artifactId>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!--
			Spring Boot Test:
			Pulls in JUnit 5, AssertJ, Mockito, MockMvc and the full Spring test
			infrastructure. MockMvc allows testing Spring MVC controllers in isolation
			without starting a real HTTP server (uses DispatcherServlet in a mock
			environment), making unit tests for controllers fast and lightweight.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Spring WebFlux (test scope only):
			WebTestClient is the fluent HTTP test client used in integration tests.
			With a servlet-stack (spring-boot-starter-web) application, Spring Boot
			does NOT auto-configure WebTestClient unless WebFlux is on the test
			classpath. Adding this dependency test-scope enables WebTestClient
			without switching the application to a reactive stack.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-webflux</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Zipkin model (test scope):
			Provides zipkin2.Span and zipkin2.reporter.AsyncReporter which are
			used in the integration test to force-flush spans to Zipkin before
			asserting they appear in the Zipkin API. This is a transitive runtime
			dependency of zipkin-reporter-brave; adding it explicitly makes the
			types available at test compile time.
		-->
		<dependency>
			<groupId>io.zipkin.zipkin2</groupId>
			<artifactId>zipkin</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers JUnit 5 integration:
			Provides @Testcontainers (class-level) and @Container (field-level)
			annotations that hook into JUnit 5's extension mechanism to manage
			Docker container lifecycle alongside test lifecycle.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers core:
			Provides GenericContainer, which is used to start a real Zipkin
			container during integration tests to verify that the application
			actually exports spans to Zipkin.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers</artifactId>
			<scope>test</scope>
		</dependency>

	</dependencies>

	<!--
		Spring Cloud BOM - manages all spring-cloud-* artefact versions
		to a set that is compatible with Spring Boot 3.4.x.
		2024.0.1 is the "2024.0" release train aligned with Spring Boot 3.4.
	-->
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.springframework.cloud</groupId>
				<artifactId>spring-cloud-dependencies</artifactId>
				<version>2024.0.1</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
			<!-- Pin all Testcontainers module versions together via the BOM -->
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin: packages the application as an executable fat-jar -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>

			<!--
				Maven Surefire Plugin: configures test execution for Java 21+.

				argLine breakdown:
				  -XX:+EnableDynamicAgentLoading  - silences Mockito/ByteBuddy agent warnings
				  -Xshare:off                      - disables class-data sharing (avoids CDS conflicts)
				  -Dnet.bytebuddy.experimental    - required on Java 25+; harmless on Java 21-24
				  add-opens                       - grants ByteBuddy/Mockito deep reflection access

				DOCKER_API_VERSION=1.44:
				  Docker Desktop 29+ rejects the legacy v1.24 API path that docker-java uses by
				  default. Setting 1.44 here (and in docker-java.properties on the test classpath)
				  ensures Testcontainers works correctly on Docker Desktop 29+.
			-->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Ensures docker-java uses API v1.44 (Docker Desktop 29+ requires this) -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>

</project>
