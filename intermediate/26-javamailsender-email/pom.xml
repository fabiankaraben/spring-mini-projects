<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>javamailsender</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>javamailsender</name>
	<description>Spring Boot mini-project demonstrating plain text and HTML email sending using JavaMailSender</description>
	<properties>
		<java.version>21</java.version>
		<!-- Testcontainers BOM version – aligns all Testcontainers module versions -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>
	<dependencies>
		<!-- Spring Boot Web – provides the embedded Tomcat server and @RestController
		     support. Exposes the REST API that clients use to trigger email sending. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!-- Spring Boot Mail – provides JavaMailSender and auto-configuration
		     for SMTP connection settings (host, port, username, password).
		     MimeMessageHelper is used to build HTML / multipart messages. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-mail</artifactId>
		</dependency>

		<!-- Bean Validation (Hibernate Validator) – validates incoming request DTOs
		     with @NotBlank, @Email, etc. Spring MVC integrates via @Valid. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!-- Spring Boot Actuator – exposes operational endpoints:
		     /actuator/health  → overall application and SMTP health
		     /actuator/info    → build and version information -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!-- Thymeleaf – server-side template engine used to render the HTML email
		     body. Templates live under src/main/resources/templates/email/. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-thymeleaf</artifactId>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!-- Spring Boot Test – JUnit 5, AssertJ, Mockito, and MockMvc integration.
		     Provides @SpringBootTest, @WebMvcTest, and @MockitoBean annotations. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Testcontainers JUnit 5 integration – @Testcontainers and @Container
		     annotations for managing Docker container lifecycles during integration tests. -->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Testcontainers core – base library for programmatic Docker container
		     management. Used to run Mailpit (SMTP test server) in integration tests. -->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers</artifactId>
			<scope>test</scope>
		</dependency>
	</dependencies>

	<dependencyManagement>
		<dependencies>
			<!-- Testcontainers BOM – aligns all Testcontainers module versions -->
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin – packages the application as an executable fat JAR -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>
			<!-- Surefire plugin with JVM args required for Mockito on Java 21+ and
			     the DOCKER_API_VERSION env var required for Testcontainers on Docker Desktop 29+ -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Testcontainers uses this to communicate with the Docker daemon.
						     Docker Desktop 29+ rejects the legacy v1.24 API; 1.44 is required. -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>
