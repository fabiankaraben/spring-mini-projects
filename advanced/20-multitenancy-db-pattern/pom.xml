<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>multitenancy-db-pattern</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>multitenancy-db-pattern</name>
	<description>
		Spring Boot mini-project demonstrating a multi-tenancy database pattern.
		Each tenant is isolated in its own PostgreSQL schema. An HTTP header
		(X-Tenant-ID) identifies the current tenant; a custom AbstractRoutingDataSource
		switches the active schema dynamically per request. The project exposes a simple
		Product CRUD API and demonstrates how rows written through one tenant's connection
		are invisible to another tenant.
		Includes JUnit 5 unit tests for domain logic and full integration tests with
		Testcontainers (PostgreSQL container).
	</description>

	<properties>
		<java.version>21</java.version>
		<!-- Testcontainers BOM version — pins all Testcontainers module versions in sync -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>

	<dependencies>

		<!--
			Spring Web (MVC):
			Provides the DispatcherServlet, @RestController, and Jackson JSON support.
			Used for the Products CRUD API and tenant-aware request interceptor.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!--
			Spring Data JPA:
			Provides JPA repositories, entity management, and Hibernate ORM.
			We use Spring Data's JpaRepository for the Product entity, but the
			underlying DataSource is switched per-tenant at the connection level.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>

		<!--
			Bean Validation (Hibernate Validator):
			Provides @NotBlank, @NotNull, @Positive etc. for DTO input validation.
			Used on request DTOs in the Products API.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!--
			Spring Boot Actuator:
			Exposes /actuator/health and /actuator/info endpoints.
			The health endpoint is used by Docker Compose healthcheck probes.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!--
			PostgreSQL JDBC Driver:
			Provides the runtime JDBC driver for connecting to PostgreSQL.
			Required by Hibernate/Spring Data JPA at runtime; not needed at compile time.
		-->
		<dependency>
			<groupId>org.postgresql</groupId>
			<artifactId>postgresql</artifactId>
			<scope>runtime</scope>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!--
			Spring Boot Test:
			Pulls in JUnit 5, AssertJ, Mockito, MockMvc, and all Spring test
			infrastructure needed for unit and integration tests.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers JUnit 5 integration:
			Provides @Testcontainers and @Container annotations that manage Docker
			container lifecycle alongside JUnit 5 test execution.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers PostgreSQL module:
			Provides PostgreSQLContainer — a pre-configured Testcontainers wrapper that
			starts a real PostgreSQL Docker container for integration tests.
			This ensures tests run against the same database engine used in production.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>postgresql</artifactId>
			<scope>test</scope>
		</dependency>

	</dependencies>

	<!--
		Manage all Testcontainers module versions through the BOM (Bill of Materials).
		This ensures all testcontainers-* artifacts from the official org.testcontainers
		group resolve to the same compatible version set.
	-->
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin: packages the application as an executable fat-jar -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>

			<!--
				Maven Surefire Plugin: configures test execution for Java 21+.

				argLine breakdown:
				  -XX:+EnableDynamicAgentLoading  — silences Mockito/ByteBuddy agent warnings
				  -Xshare:off                     — disables class-data sharing (avoids conflicts)
				  -Dnet.bytebuddy.experimental    — required on Java 25+; harmless on Java 21-24
				  add-opens                       — grants ByteBuddy/Mockito deep reflection access

				DOCKER_API_VERSION=1.44:
				  Docker Desktop 29+ rejects the legacy v1.24 API path that docker-java uses by
				  default. Setting 1.44 here (and in docker-java.properties on the test classpath)
				  ensures Testcontainers works correctly on Docker Desktop 29+.
			-->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Ensures docker-java uses API v1.44 (Docker Desktop 29+ requires this) -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>

</project>
