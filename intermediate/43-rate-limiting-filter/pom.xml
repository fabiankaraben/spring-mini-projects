<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>ratelimitingfilter</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>ratelimitingfilter</name>
	<description>Spring Boot mini-project implementing a token-bucket rate limiter via a Spring HandlerInterceptor backed by Redis</description>
	<properties>
		<java.version>21</java.version>
		<!-- Testcontainers BOM version – aligns all Testcontainers module versions -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>
	<dependencies>
		<!-- Spring Web (MVC) – REST controllers, DispatcherServlet, Jackson JSON -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!-- Spring Data Redis – RedisTemplate and connection factory for Redis -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-redis</artifactId>
		</dependency>

		<!-- Lettuce (default Redis client) – async, non-blocking Redis driver -->
		<!-- Included transitively via spring-boot-starter-data-redis -->

		<!-- Spring Boot Actuator – /actuator/health and metrics endpoints -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!-- ===== Test dependencies ===== -->
		<!-- Spring Boot Test – JUnit 5, MockMvc, AssertJ, Mockito integration -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>
		<!-- Testcontainers JUnit 5 integration – @Testcontainers, @Container -->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>
		<!-- Testcontainers Redis module – spins up a real Redis container for tests -->
		<!-- Uses the generic container image; no dedicated Redis module needed -->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers</artifactId>
			<scope>test</scope>
		</dependency>
	</dependencies>

	<dependencyManagement>
		<dependencies>
			<!-- Import the Testcontainers BOM so all module versions stay in sync -->
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin – packages the application as an executable JAR -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>
			<!-- Surefire plugin with JVM args required for Mockito on Java 21+ -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Testcontainers uses this to communicate with the Docker daemon -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>
