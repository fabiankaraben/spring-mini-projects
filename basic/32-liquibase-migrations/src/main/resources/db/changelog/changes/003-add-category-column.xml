<?xml version="1.0" encoding="UTF-8"?>
<!--
  003-add-category-column.xml
  ============================
  Changeset 3: Adds a 'category' column to the existing 'products' table.

  This changeset demonstrates the most common real-world Liquibase use case:
  evolving a schema AFTER it already has data.

  Strategy used here (safe migration pattern):
  1. Add the column as nullable (no default, so existing rows get NULL).
  2. Back-fill the existing rows with a meaningful default value.
  3. Add a NOT NULL constraint once all rows have a value.

  This three-step process avoids locking the entire table in databases
  that don't support adding a NOT NULL column with a default safely.

  Key Liquibase concept: <addColumn> + <update> + <addNotNullConstraint>
-->
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="003" author="example">

        <!-- Step 1: Add the column allowing NULL temporarily -->
        <addColumn tableName="products">
            <column name="category" type="VARCHAR(80)"
                    remarks="Product category; added in migration 003."/>
        </addColumn>

        <!-- Step 2: Back-fill existing rows with a default category.
             The products inserted in changeset 002 are all 'Electronics'. -->
        <update tableName="products">
            <column name="category" value="Electronics"/>
            <!-- No WHERE clause means all rows are updated -->
        </update>

        <!-- Step 3: Now that all rows have a value, enforce NOT NULL -->
        <addNotNullConstraint
                tableName="products"
                columnName="category"
                columnDataType="VARCHAR(80)"/>

        <!--
          rollback: undo this changeset by dropping the newly added column.
          PostgreSQL supports DROP COLUMN directly.
        -->
        <rollback>
            <dropColumn tableName="products" columnName="category"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
