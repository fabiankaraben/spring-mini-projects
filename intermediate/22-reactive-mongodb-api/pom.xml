<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>reactivemongodbapi</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>reactivemongodbapi</name>
	<description>Spring Boot mini-project demonstrating a fully non-blocking stack with Spring WebFlux and Reactive MongoDB</description>
	<properties>
		<java.version>21</java.version>
		<!-- Testcontainers BOM version – aligns all Testcontainers module versions -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>
	<dependencies>
		<!-- Spring WebFlux – reactive, non-blocking web framework based on Project Reactor.
		     Provides @RestController with Mono<T> and Flux<T> return types.
		     Uses Netty as the default embedded server instead of the traditional
		     servlet-based Tomcat. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-webflux</artifactId>
		</dependency>

		<!-- Spring Data Reactive MongoDB – provides ReactiveMongoRepository and
		     ReactiveMongoTemplate. All database operations return Mono<T> or Flux<T>
		     so no thread is ever blocked waiting for a MongoDB response.
		     This is the reactive counterpart of Spring Data MongoDB (blocking). -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-mongodb-reactive</artifactId>
		</dependency>

		<!-- Bean Validation (Hibernate Validator) – @NotBlank, @Min, @DecimalMin, etc.
		     on request DTOs. Spring WebFlux integrates with validation via @Valid. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!-- Spring Boot Test – JUnit 5, AssertJ, Mockito, WebTestClient integration.
		     WebTestClient is the reactive-aware replacement for TestRestTemplate. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Reactor Test – StepVerifier for testing Mono/Flux pipelines step-by-step
		     without blocking. Essential for verifying reactive stream behaviour. -->
		<dependency>
			<groupId>io.projectreactor</groupId>
			<artifactId>reactor-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Testcontainers JUnit 5 integration – @Testcontainers and @Container
		     annotations for managing Docker container lifecycles during integration tests. -->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Testcontainers MongoDB module – spins up a real MongoDB container for
		     integration tests, replacing the need for a locally installed MongoDB. -->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>mongodb</artifactId>
			<scope>test</scope>
		</dependency>
	</dependencies>

	<dependencyManagement>
		<dependencies>
			<!-- Import the Testcontainers BOM so all module versions stay in sync -->
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin – packages the application as an executable JAR -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>
			<!-- Surefire plugin with JVM args required for Mockito on Java 21+ and
			     the DOCKER_API_VERSION env var required for Testcontainers on Docker Desktop 29+ -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Testcontainers uses this to communicate with the Docker daemon.
						     Docker Desktop 29+ rejects the legacy v1.24 API; 1.44 is required. -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>
