<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<!--
		CQRS with Axon Framework - Spring Boot mini-project.

		Command Query Responsibility Segregation (CQRS) is an architectural pattern
		that separates the read model (queries) from the write model (commands).

		Axon Framework is a Java framework that provides first-class support for:
		  - CQRS: separate command handlers and query handlers
		  - Event Sourcing: aggregates are rebuilt from a stream of past events
		  - Domain-Driven Design: aggregates, value objects, domain events

		Domain: An Order management system where:
		  - Commands mutate state  (PlaceOrderCommand, ConfirmOrderCommand, CancelOrderCommand)
		  - Events record what happened (OrderPlacedEvent, OrderConfirmedEvent, OrderCancelledEvent)
		  - The Order aggregate enforces business rules
		  - A read-model projection (OrderSummary) is updated by listening to events

		Axon ships an in-process event bus by default (no external broker required),
		which keeps this project self-contained for local development.
		For production use, Axon Server (or an AMQP/Kafka event bus) would replace
		the in-process bus to enable multi-node deployments.
	-->

	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/>
	</parent>

	<groupId>com.example.cqrs</groupId>
	<artifactId>cqrs-with-axon</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>cqrs-with-axon</name>
	<description>
		Spring Boot mini-project demonstrating CQRS and Event Sourcing with Axon Framework.
		Separates the write model (commands + aggregates) from the read model (projections + queries).
	</description>

	<properties>
		<java.version>21</java.version>
		<!-- Axon Framework BOM version - pins all Axon module versions -->
		<axon.version>4.10.3</axon.version>
		<!-- Testcontainers BOM version -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>

	<dependencyManagement>
		<dependencies>
			<!--
				Axon Framework BOM: imports all Axon module versions so child
				dependencies do not need to repeat the version number.
			-->
			<dependency>
				<groupId>org.axonframework</groupId>
				<artifactId>axon-bom</artifactId>
				<version>${axon.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>

			<!--
				Testcontainers BOM: pins all Testcontainers module versions in sync
				so we never accidentally mix incompatible versions.
			-->
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<dependencies>

		<!-- ===== Spring Boot starters ===== -->

		<!--
			Spring Web: provides the embedded Tomcat server and Spring MVC.
			Used to expose the REST API for commands and queries.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!--
			Spring Data JPA: ORM layer backed by Hibernate.
			Used for the read-model (OrderSummary projection) stored in PostgreSQL.
			The write model is stored in the Axon event store (also PostgreSQL).
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>

		<!--
			Spring Boot Validation: Bean Validation (JSR-380) via Hibernate Validator.
			Used to validate incoming REST request bodies (@NotNull, @Positive, etc.).
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!--
			Spring Boot Actuator: exposes /actuator/health used by Docker health checks.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!-- ===== Axon Framework ===== -->

		<!--
			Axon Spring Boot Starter: auto-configures the Axon Framework components:
			  - CommandBus: routes commands to @CommandHandler methods
			  - EventBus: distributes events to @EventHandler methods
			  - QueryBus: routes queries to @QueryHandler methods
			  - EventStore: persists events (backed by JPA/PostgreSQL via axon-jpa below)
			  - Repository<T>: EventSourcingRepository for loading aggregates from events

			In this project we use the in-process (embedded) event bus - no Axon Server
			or message broker is required. This is the simplest setup and ideal for
			learning CQRS/ES concepts.
		-->
		<dependency>
			<groupId>org.axonframework</groupId>
			<artifactId>axon-spring-boot-starter</artifactId>
			<!--
				Exclude Axon Server connector: by default the starter tries to connect
				to Axon Server. We don't use Axon Server here; instead we use the
				JPA-backed event store (EmbeddedEventStore + JpaEventStorageEngine).
			-->
			<exclusions>
				<exclusion>
					<groupId>org.axonframework</groupId>
					<artifactId>axon-server-connector</artifactId>
				</exclusion>
			</exclusions>
		</dependency>

		<!--
			Axon Messaging: core messaging abstractions (commands, events, queries).
			Transitively included by axon-spring-boot-starter but listed explicitly
			for documentation clarity.
		-->
		<dependency>
			<groupId>org.axonframework</groupId>
			<artifactId>axon-messaging</artifactId>
		</dependency>

		<!--
			Axon Eventsourcing: provides the event sourcing infrastructure including
			EventSourcingHandler, EventSourcingRepository, and the snapshot mechanism.
		-->
		<dependency>
			<groupId>org.axonframework</groupId>
			<artifactId>axon-eventsourcing</artifactId>
		</dependency>

		<!-- ===== Database ===== -->

		<!--
			PostgreSQL JDBC driver: runtime dependency for both the Axon JPA event store
			and the read-model (OrderSummary) JPA repository.
		-->
		<dependency>
			<groupId>org.postgresql</groupId>
			<artifactId>postgresql</artifactId>
			<scope>runtime</scope>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!--
			Spring Boot Test: JUnit 5, AssertJ, Mockito and Spring test infrastructure.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Axon Test: provides the AggregateTestFixture which allows testing an
			aggregate in isolation using a fluent given-when-then style without
			needing a running Spring context or database.

			Example:
			  fixture.given(new OrderPlacedEvent(...))
			         .when(new ConfirmOrderCommand(...))
			         .expectEvents(new OrderConfirmedEvent(...));
		-->
		<dependency>
			<groupId>org.axonframework</groupId>
			<artifactId>axon-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers JUnit 5 integration: @Testcontainers + @Container annotations
			manage Docker container lifecycle alongside the JUnit 5 test lifecycle.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers PostgreSQL module: starts a real PostgreSQL container for
			integration tests, ensuring the JPA event store and the read-model
			repository are tested against a real database (not H2).
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>postgresql</artifactId>
			<scope>test</scope>
		</dependency>

	</dependencies>

	<build>
		<plugins>
			<!--
				Spring Boot Maven Plugin: packages the application as an executable
				fat-jar (with embedded Tomcat) suitable for running in Docker.
			-->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>

			<!--
				Maven Surefire Plugin: configures test execution for Java 21+.

				argLine breakdown:
				  -XX:+EnableDynamicAgentLoading  : silences Mockito/ByteBuddy agent warnings
				  -Xshare:off                     : disables class-data sharing (avoids conflicts)
				  -Dnet.bytebuddy.experimental    : required on Java 25+; harmless on Java 21-24
				  add-opens                       : grants ByteBuddy/Mockito deep reflection access

				DOCKER_API_VERSION=1.44:
				  Docker Desktop 29+ rejects the legacy v1.24 API that docker-java uses by
				  default. Setting 1.44 here (and in docker-java.properties on the test classpath)
				  ensures Testcontainers works correctly on Docker Desktop 29+.
			-->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>

</project>
