<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>keycloak-identity</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>keycloak-identity</name>
	<description>
		Spring Boot mini-project demonstrating how to delegate user authentication entirely to
		a Keycloak SSO server. The backend acts as an OAuth2 Resource Server, accepting JWT
		Bearer tokens issued by Keycloak. Demonstrates OIDC-based authentication, role-based
		and scope-based access control, JWT claims extraction, and a Users API domain.
		Includes JUnit 5 unit tests for domain logic and full integration tests with
		Testcontainers (Keycloak container + WireMock for JWK Set stubbing).
	</description>

	<properties>
		<java.version>21</java.version>
		<!-- Testcontainers BOM version — pins all Testcontainers module versions in sync -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>

	<dependencies>

		<!--
			Spring Boot OAuth2 Resource Server:
			The core dependency that wires Keycloak JWT validation into Spring Security.
			It provides:
			  - BearerTokenAuthenticationFilter: extracts the Bearer token from every request
			  - NimbusJwtDecoder: fetches Keycloak's public keys via the JWKS URI and
			    verifies every incoming JWT signature
			  - JwtAuthenticationConverter: maps Keycloak JWT claims (realm_access.roles,
			    scope) to Spring Security GrantedAuthority objects
			  - Auto-configuration via spring.security.oauth2.resourceserver.jwt.*
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-oauth2-resource-server</artifactId>
		</dependency>

		<!--
			Spring Web (MVC):
			Provides the DispatcherServlet, @RestController, and Jackson JSON support.
			Used for the Users API and the public info endpoints.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!--
			Bean Validation (Hibernate Validator):
			Provides @NotBlank, @NotNull, @Email etc. for DTO input validation.
			Used on request DTOs in the Users API.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!--
			Spring Boot Actuator:
			Exposes /actuator/health and /actuator/info endpoints.
			The health endpoint is used by Docker Compose healthcheck probes.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!--
			Spring Boot Test:
			Pulls in JUnit 5, AssertJ, Mockito, MockMvc, and all Spring test
			infrastructure needed for unit and integration tests.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Spring Security Test:
			Provides SecurityMockMvcRequestPostProcessors such as jwt() which
			injects a fake JwtAuthenticationToken directly into the security context —
			bypassing real JWT signature verification during tests.
			This allows testing access control rules without a running Keycloak server.
		-->
		<dependency>
			<groupId>org.springframework.security</groupId>
			<artifactId>spring-security-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers JUnit 5 integration:
			Provides @Testcontainers and @Container annotations that manage Docker
			container lifecycle alongside JUnit 5 test execution.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers core module:
			Provides GenericContainer used to run WireMock as a mock Keycloak JWKS
			endpoint and Keycloak itself during integration tests.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers Keycloak module (via dasniko/testcontainers-keycloak):
			A community module that wraps the official Keycloak Docker image with a
			convenient Java API. It provides KeycloakContainer with helpers for
			creating realm configurations, obtaining admin tokens, and retrieving
			the JWKS URI automatically.

			NOTE: This artifact is published under the groupId 'com.github.dasniko'
			and does NOT go through the Testcontainers BOM — it is versioned separately.
		-->
		<dependency>
			<groupId>com.github.dasniko</groupId>
			<artifactId>testcontainers-keycloak</artifactId>
			<version>3.5.0</version>
			<scope>test</scope>
		</dependency>

	</dependencies>

	<!--
		Manage all Testcontainers module versions through the BOM (Bill of Materials).
		This ensures all testcontainers-* artifacts from the official org.testcontainers
		group resolve to the same compatible version set.
		Note: dasniko/testcontainers-keycloak is NOT covered by this BOM.
	-->
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin: packages the application as an executable fat-jar -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>

			<!--
				Maven Surefire Plugin: configures test execution for Java 21+.

				argLine breakdown:
				  -XX:+EnableDynamicAgentLoading  — silences Mockito/ByteBuddy agent warnings
				  -Xshare:off                     — disables class-data sharing (avoids conflicts)
				  -Dnet.bytebuddy.experimental    — required on Java 25+; harmless on Java 21-24
				  add-opens                       — grants ByteBuddy/Mockito deep reflection access

				DOCKER_API_VERSION=1.44:
				  Docker Desktop 29+ rejects the legacy v1.24 API path that docker-java uses by
				  default. Setting 1.44 here (and in docker-java.properties on the test classpath)
				  ensures Testcontainers works correctly on Docker Desktop 29+.
			-->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Ensures docker-java uses API v1.44 (Docker Desktop 29+ requires this) -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>

</project>
