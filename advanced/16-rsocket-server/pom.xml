<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<!--
		RSocket Server mini-project.

		This project demonstrates how to build a reactive, backpressure-aware
		communication backend in Spring Boot using RSocket.

		What is RSocket?
		  RSocket is a binary, multiplexed, reactive application-level protocol
		  designed for reactive streams and backpressure over TCP, WebSocket, or
		  other transport layers. Key characteristics:
		    - Protocol-level backpressure — the consumer controls how many items
		      it is ready to receive, preventing overwhelming slow consumers.
		    - Four interaction models (all demonstrated in this project):
		        1. Request-Response   — single request → single response (like HTTP).
		        2. Request-Stream     — single request → multiple responses (server pushes).
		        3. Fire-and-Forget    — single request with no response expected.
		        4. Request-Channel    — bidirectional stream (many requests → many responses).
		    - Built on Project Reactor (Mono/Flux), so the entire pipeline is
		      non-blocking and reactive from end to end.
		    - Resume capability — clients can reconnect and resume a stream after
		      a transient network failure without losing messages.

		Why RSocket over REST/WebSocket?
		  - REST is strictly request-response; RSocket supports all four models.
		  - RSocket has native backpressure at the protocol level (not just application).
		  - Binary framing is more efficient than HTTP text headers.
		  - Ideal for real-time microservice communication, IoT event streams, and
		    any use case requiring bidirectional or server-push patterns.

		Domain scenario: a Stock Market Ticker service.
		  Operations provided:
		    1. getQuote (Request-Response)   — fetch the latest price for a stock symbol.
		    2. streamQuotes (Request-Stream) — subscribe to a live price stream for a symbol.
		    3. logTrade (Fire-and-Forget)    — record a trade event (no response needed).
		    4. priceAlerts (Request-Channel) — send a stream of watched symbols, receive
		                                        back a stream of alert events when thresholds
		                                        are crossed.

		Technology stack:
		  - Spring Boot 3.4.x + spring-boot-starter-rsocket
		    Auto-configures an RSocket server on a TCP port (default: 7000).
		    Uses @MessageMapping and @Controller annotations (same model as @RestController).
		  - Project Reactor (Mono/Flux) — reactive streams implementation.
		    Mono<T>  represents 0..1 items (used for request-response).
		    Flux<T>  represents 0..N items (used for streaming and channel).
		  - Spring Data JPA + H2 — in-memory persistence for quotes and trades.
		  - Spring Boot Actuator — health endpoint on HTTP port 8080.

		Port layout:
		  7000 — RSocket TCP server (all four interaction model routes)
		  8080 — Spring Boot HTTP (Actuator /health, /info)
	-->

	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/>
	</parent>

	<groupId>com.example.rsocket</groupId>
	<artifactId>rsocket-server</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>rsocket-server</name>
	<description>
		Spring Boot mini-project implementing reactive, backpressure-aware communication
		over RSocket. Demonstrates all four RSocket interaction models (request-response,
		request-stream, fire-and-forget, request-channel) with a Stock Market Ticker domain.
		Includes JUnit 5 unit tests and full integration tests using Testcontainers.
	</description>

	<properties>
		<java.version>21</java.version>

		<!--
			Testcontainers BOM version — pins all Testcontainers module versions in sync.
		-->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>

	<dependencies>

		<!--
			Spring Boot Web (Spring MVC + embedded Tomcat):
			Provides the HTTP server on port 8080 for Spring Actuator endpoints.
			The RSocket server runs on a separate TCP port (7000) managed by
			spring-boot-starter-rsocket.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!--
			Spring Boot Actuator:
			Exposes /actuator/health and /actuator/info on port 8080.
			Used by Docker health checks to verify the application is ready.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!--
			Spring Boot RSocket starter:
			Auto-configures a fully managed RSocket server backed by Netty (via
			reactor-netty). Key features:
			  - Scans for @Controller + @MessageMapping annotated classes.
			  - Binds the RSocket server to a configurable TCP port (spring.rsocket.server.port).
			  - Integrates with Project Reactor for end-to-end reactive handling.
			  - Supports all four RSocket interaction models out of the box.
			  - Optionally enables RSocket over WebSocket transport.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-rsocket</artifactId>
		</dependency>

		<!--
			Spring Data JPA + Hibernate:
			Provides JPA repository abstraction over H2.
			Handles entity management and SQL generation for stock quotes and trade records.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>

		<!--
			H2 in-memory database:
			Lightweight embedded SQL database used as the persistence layer.
			All data lives in memory and resets on restart.
			In production, replace with PostgreSQL, MySQL, etc.
		-->
		<dependency>
			<groupId>com.h2database</groupId>
			<artifactId>h2</artifactId>
			<scope>runtime</scope>
		</dependency>

		<!--
			Spring Boot Validation (Hibernate Validator / Jakarta Bean Validation):
			Enables @Valid and constraint annotations (@NotBlank, @Positive, etc.)
			on domain model fields.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!--
			Spring Boot Test:
			Pulls in JUnit 5, AssertJ, Mockito, and Spring test infrastructure.
			Also includes spring-test which provides @SpringBootTest and
			RSocketRequester support for RSocket integration testing.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			reactor-test:
			Provides StepVerifier — a powerful test utility for verifying reactive
			streams (Mono/Flux). Lets us assert that a reactive pipeline emits
			specific items, completes, or errors in the expected order.
		-->
		<dependency>
			<groupId>io.projectreactor</groupId>
			<artifactId>reactor-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers JUnit 5 integration:
			@Testcontainers + @Container annotations manage Docker container lifecycle
			alongside the JUnit 5 test lifecycle.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers core:
			Provides GenericContainer and the Docker client integration.
			Used to verify Docker daemon availability during integration tests.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers</artifactId>
			<scope>test</scope>
		</dependency>

	</dependencies>

	<!--
		Manage Testcontainers module versions through the BOM (Bill of Materials).
		This ensures all testcontainers:* artifacts resolve to a compatible version set.
	-->
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>

			<!--
				Spring Boot Maven Plugin:
				Packages the application as an executable fat-jar (uber-jar) with all
				dependencies embedded. Run with: java -jar rsocket-server.jar
			-->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>

			<!--
				Maven Surefire Plugin: configures test execution for Java 21+.

				argLine breakdown:
				  -XX:+EnableDynamicAgentLoading  silences Mockito/ByteBuddy agent warnings on Java 21+
				  -Xshare:off                     disables class-data sharing (avoids rare JVM conflicts)
				  -Dnet.bytebuddy.experimental    required on Java 25+; harmless on Java 21–24
				  add-opens flags                 grant ByteBuddy/Mockito deep reflection access

				DOCKER_API_VERSION=1.44:
				  Docker Desktop 29+ rejects the legacy v1.24 API path used by docker-java.
				  Setting 1.44 here (and in docker-java.properties on the test classpath)
				  ensures Testcontainers works correctly on Docker Desktop 29+.
			-->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Ensures docker-java uses API v1.44 (Docker Desktop 29+ requires this) -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>

		</plugins>
	</build>

</project>
