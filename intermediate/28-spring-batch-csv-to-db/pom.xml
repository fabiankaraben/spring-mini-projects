<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>spring-batch-csv-to-db</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>spring-batch-csv-to-db</name>
	<description>Spring Boot mini-project that reads a CSV file and stores valid rows into a PostgreSQL database using Spring Batch</description>
	<properties>
		<java.version>21</java.version>
		<!-- Testcontainers BOM version – aligns all Testcontainers module versions -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>
	<dependencies>
		<!-- Spring Boot Web – provides the embedded Tomcat server and @RestController
		     support. Exposes the REST API for triggering batch jobs and querying results. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!-- Spring Boot Batch – core Spring Batch auto-configuration, the Job
		     repository, the ItemReader / ItemProcessor / ItemWriter infrastructure,
		     and the batch execution meta-data tables. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-batch</artifactId>
		</dependency>

		<!-- Spring Boot Data JPA – provides the EntityManager and Spring Data
		     repository abstraction used to query the imported Employee records. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>

		<!-- Bean Validation (Hibernate Validator) – validates CSV row data with
		     @NotBlank, @Email, @Positive, etc. inside the ItemProcessor. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!-- Spring Boot Actuator – exposes /actuator/health and /actuator/info
		     endpoints for operational visibility. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!-- PostgreSQL JDBC Driver – connects to the PostgreSQL database at runtime.
		     Scope is "runtime" because we only need it on the classpath at runtime,
		     not for compilation. -->
		<dependency>
			<groupId>org.postgresql</groupId>
			<artifactId>postgresql</artifactId>
			<scope>runtime</scope>
		</dependency>

		<!-- Flyway – database migration tool. Runs SQL migration scripts on startup
		     to create the employees table and Spring Batch meta-data tables. -->
		<dependency>
			<groupId>org.flywaydb</groupId>
			<artifactId>flyway-database-postgresql</artifactId>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!-- Spring Boot Test – JUnit 5, AssertJ, Mockito, and MockMvc integration.
		     Provides @SpringBootTest, @WebMvcTest, and @MockitoBean annotations. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Spring Batch Test – provides JobLauncherTestUtils, @SpringBatchTest,
		     and AssertJ-based JobExecution assertion helpers. -->
		<dependency>
			<groupId>org.springframework.batch</groupId>
			<artifactId>spring-batch-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Testcontainers JUnit 5 integration – @Testcontainers and @Container
		     annotations for managing Docker container lifecycles during tests. -->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Testcontainers core – base library for programmatic Docker container
		     management used in integration tests. -->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Testcontainers PostgreSQL module – convenience wrapper that starts a
		     PostgreSQL container and exposes the JDBC URL via getDatabaseUrl(). -->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>postgresql</artifactId>
			<scope>test</scope>
		</dependency>
	</dependencies>

	<dependencyManagement>
		<dependencies>
			<!-- Testcontainers BOM – aligns all Testcontainers module versions -->
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin – packages the application as an executable fat JAR -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>
			<!-- Surefire plugin with JVM args required for Mockito on Java 21+ and
			     the DOCKER_API_VERSION env var required for Testcontainers on Docker Desktop 29+ -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Testcontainers uses this to communicate with the Docker daemon.
						     Docker Desktop 29+ rejects the legacy v1.24 API; 1.44 is required. -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>
