<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>docker-compose-support</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>docker-compose-support</name>
	<description>Spring Boot 3.1+ Docker Compose Support demo — automatic dev service lifecycle management</description>

	<properties>
		<java.version>21</java.version>
		<!-- Testcontainers BOM version for integration tests -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>

	<dependencies>
		<!-- Spring Boot Web: provides REST API support via Spring MVC -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!-- Spring Boot Validation: Bean Validation (JSR-380) for request DTOs -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!--
			Spring Data JPA: ORM abstraction for relational databases.
			Used here to persist Book records in PostgreSQL.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>

		<!--
			PostgreSQL JDBC driver.
			In development, Spring Boot's Docker Compose integration automatically
			starts the PostgreSQL container defined in compose.yml and wires the
			datasource — no manual connection string needed.
		-->
		<dependency>
			<groupId>org.postgresql</groupId>
			<artifactId>postgresql</artifactId>
			<scope>runtime</scope>
		</dependency>

		<!--
			Spring Boot Docker Compose Support (spring-boot-docker-compose).
			This is the key dependency for this mini-project.

			When present on the classpath and a compose.yml (or docker-compose.yml)
			file is found in the working directory, Spring Boot will:
			  1. Automatically run `docker compose up` before starting the application.
			  2. Override DataSource (and other service) connection properties so
			     the app connects to the containers that were just started.
			  3. Run `docker compose stop` when the application shuts down.

			This removes the need to start Docker services manually during development.
			It is scoped to 'developmentOnly' (or omitted from production builds).

			Key properties in application.yml:
			  spring.docker.compose.enabled=true         (default when dep is present)
			  spring.docker.compose.file=compose.yml     (path to the compose file)
			  spring.docker.compose.lifecycle-management=start-and-stop  (default)
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-docker-compose</artifactId>
			<scope>runtime</scope>
			<optional>true</optional>
		</dependency>

		<!-- Spring Boot Test: JUnit 5, Mockito, MockMvc, AssertJ, etc. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Testcontainers JUnit 5 integration: @Testcontainers + @Container lifecycle -->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers PostgreSQL module: spins up a real PostgreSQL container
			during integration tests using the official postgres Docker image.
			This lets us test full database interaction without an external DB.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>postgresql</artifactId>
			<scope>test</scope>
		</dependency>
	</dependencies>

	<!-- Manage all Testcontainers module versions via BOM -->
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin: packages the app as an executable fat-jar -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>

			<!-- Maven Surefire Plugin: configures test execution -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<!--
						JVM args required for Java 21+:
						- EnableDynamicAgentLoading: silences Mockito byte-buddy agent warnings
						- Xshare:off: avoids class-sharing conflicts with dynamic agents
						- net.bytebuddy.experimental: required on Java 25+ (not needed on 21 but harmless)
						- add-opens: needed by Mockito/ByteBuddy for deep reflection
					-->
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Ensures docker-java uses API v1.44 (Docker Desktop 29+ requires this) -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>
