<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<!--
		gRPC Server Integration mini-project.

		This project demonstrates how to expose Spring Boot business logic as
		high-performance, strongly-typed RPC endpoints using gRPC and Protocol Buffers.

		What is gRPC?
		  gRPC is a modern, open-source Remote Procedure Call (RPC) framework developed
		  by Google. It uses:
		    - Protocol Buffers (protobuf) as its Interface Definition Language (IDL)
		      and binary serialization format — much more compact and faster than JSON.
		    - HTTP/2 as the transport protocol — enabling multiplexed streams, header
		      compression, and bidirectional communication on a single TCP connection.
		    - Code generation — the protoc compiler generates client stubs and server
		      base classes from .proto files, eliminating manual serialization code.

		Why gRPC over REST?
		  - Significantly lower payload size (binary vs text).
		  - Faster serialization / deserialization.
		  - Strongly typed contracts enforced at compile time.
		  - Native support for streaming RPCs (server-streaming, client-streaming,
		    bidirectional-streaming) — not covered by standard REST.
		  - Ideal for internal microservice communication.

		Domain scenario: a Product Catalog service for an e-commerce platform.
		  RPC methods provided:
		    1. GetProduct       — retrieve a single product by ID (unary RPC).
		    2. ListProducts     — retrieve all products, with optional category filter
		                         (server-streaming RPC).
		    3. CreateProduct    — create a new product (unary RPC).
		    4. UpdateStock      — adjust stock quantity for a product (unary RPC).
		    5. DeleteProduct    — soft-delete a product by ID (unary RPC).

		Technology stack:
		  - Spring Boot 3.4.x + grpc-spring-boot-starter (yidongnan/grpc-spring-boot-starter)
		    or net.devh:grpc-server-spring-boot-starter — auto-configures the gRPC server
		    on a dedicated port (default: 9090), separate from the HTTP actuator port (8080).
		  - protobuf-maven-plugin — invokes protoc + the gRPC Java plugin at build time to
		    generate Java stubs from src/main/proto/*.proto files.
		  - In-memory H2 database + Spring Data JPA — persistence layer for the demo.
		  - Spring Boot Actuator — health endpoint on port 8080 for Docker health checks.

		Port layout:
		  8080 — Spring Boot HTTP (Actuator /health, /info)
		  9090 — gRPC server (ProductCatalogService)
	-->

	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/>
	</parent>

	<groupId>com.example.grpc</groupId>
	<artifactId>grpc-server-integration</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>grpc-server-integration</name>
	<description>
		Spring Boot mini-project exposing highly efficient protobuf-based RPC endpoints
		using gRPC. Demonstrates a Product Catalog service with unary and server-streaming
		RPCs, Spring Data JPA persistence, JUnit 5 unit tests, and full integration tests
		using Testcontainers.
	</description>

	<properties>
		<java.version>21</java.version>

		<!--
			grpc-spring-boot-starter version.
			net.devh:grpc-server-spring-boot-starter auto-configures a Netty-based gRPC
			server and integrates with Spring's application context, health indicators, etc.
		-->
		<grpc-spring-boot-starter.version>3.1.0.RELEASE</grpc-spring-boot-starter.version>

		<!--
			Protocol Buffers Java runtime version.
			Must be kept in sync with the version used by the gRPC libraries.
		-->
		<protobuf.version>3.25.5</protobuf.version>

		<!--
			gRPC Java library version.
			Provides the core gRPC runtime, stub generation support, and Netty transport.
		-->
		<grpc.version>1.68.1</grpc.version>

		<!--
			Testcontainers BOM version — pins all Testcontainers module versions in sync.
		-->
		<testcontainers.version>1.21.3</testcontainers.version>

		<!--
			protobuf-maven-plugin version.
			Runs protoc + grpc-java plugin at build time to generate Java stubs from .proto files.
		-->
		<protobuf-maven-plugin.version>0.6.1</protobuf-maven-plugin.version>

		<!--
			os-maven-plugin version.
			Detects the current OS/architecture so the correct protoc binary is downloaded.
		-->
		<os-maven-plugin.version>1.7.1</os-maven-plugin.version>
	</properties>

	<dependencies>

		<!--
			Spring Boot Web (Spring MVC + embedded Tomcat):
			Provides the HTTP server on port 8080 for Spring Actuator endpoints.
			The gRPC server runs on a separate port (9090) via Netty.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!--
			Spring Boot Actuator:
			Exposes /actuator/health and /actuator/info endpoints on port 8080.
			Used by Docker health checks to verify the application is ready.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!--
			Spring Data JPA + Hibernate:
			Provides the JPA repository abstraction (CrudRepository / JpaRepository)
			over the H2 in-memory database. Handles entity management and SQL generation.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>

		<!--
			H2 in-memory database:
			A lightweight, embedded SQL database used as the persistence layer for this
			demo. All data lives in memory and is reset when the application restarts.
			For production use, replace with PostgreSQL, MySQL, etc.
		-->
		<dependency>
			<groupId>com.h2database</groupId>
			<artifactId>h2</artifactId>
			<scope>runtime</scope>
		</dependency>

		<!--
			Spring Boot Validation (Hibernate Validator / Jakarta Bean Validation):
			Enables @Valid and constraint annotations (@NotBlank, @Min, etc.)
			on service layer inputs.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!--
			grpc-server-spring-boot-starter (net.devh):
			Auto-configures a fully managed gRPC server powered by Netty.
			Key features:
			  - Scans for @GrpcService-annotated classes and registers them.
			  - Binds the gRPC server to a configurable port (grpc.server.port=9090).
			  - Integrates with Spring's lifecycle (starts/stops with the context).
			  - Provides a Spring Boot health indicator for the gRPC server.
			  - Supports TLS, interceptors, and reflection service configuration.
		-->
		<dependency>
			<groupId>net.devh</groupId>
			<artifactId>grpc-server-spring-boot-starter</artifactId>
			<version>${grpc-spring-boot-starter.version}</version>
		</dependency>

		<!--
			Protocol Buffers Java runtime:
			Core library for serializing and deserializing protobuf messages.
			Generated code from .proto files depends on this at runtime.
		-->
		<dependency>
			<groupId>com.google.protobuf</groupId>
			<artifactId>protobuf-java</artifactId>
			<version>${protobuf.version}</version>
		</dependency>

		<!--
			protobuf-java-util:
			Provides JsonFormat — a utility to convert protobuf messages to/from JSON.
			Useful for debugging and for HTTP endpoints that expose gRPC data as JSON.
		-->
		<dependency>
			<groupId>com.google.protobuf</groupId>
			<artifactId>protobuf-java-util</artifactId>
			<version>${protobuf.version}</version>
		</dependency>

		<!--
			javax.annotation-api:
			The gRPC Java code generator (protoc-gen-grpc-java) emits
			@javax.annotation.Generated on the generated stub classes.
			This annotation was part of the JDK up to Java 8 but was removed
			in Java 9+ when the javax.annotation module was no longer bundled.
			Adding this dependency restores it to the compile classpath.
		-->
		<dependency>
			<groupId>javax.annotation</groupId>
			<artifactId>javax.annotation-api</artifactId>
			<version>1.3.2</version>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!--
			Spring Boot Test:
			Pulls in JUnit 5, AssertJ, Mockito, MockMvc, and Spring test infrastructure.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			grpc-client-spring-boot-starter (net.devh):
			Auto-configures gRPC channel and stub beans for integration tests.
			Allows the test to connect to the running gRPC server using
			@GrpcClient-annotated stubs or manually created channels.
		-->
		<dependency>
			<groupId>net.devh</groupId>
			<artifactId>grpc-client-spring-boot-starter</artifactId>
			<version>${grpc-spring-boot-starter.version}</version>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers JUnit 5 integration:
			@Testcontainers + @Container annotations manage Docker container lifecycle
			alongside the JUnit 5 test lifecycle (start before tests, stop after).
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers core:
			Provides GenericContainer and the Docker client integration.
			Used to spin up auxiliary containers (e.g., a PostgreSQL or any sidecar)
			if needed. For this project the app itself is tested as a running process,
			so the Testcontainers core is used to assert Docker connectivity.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers</artifactId>
			<scope>test</scope>
		</dependency>

	</dependencies>

	<!--
		Manage Testcontainers module versions through the BOM (Bill of Materials).
		This ensures all testcontainers:* artifacts resolve to a compatible version set.
	-->
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>

		<!--
			os-maven-plugin (build extension):
			Detects the current OS and CPU architecture (e.g., linux-x86_64, osx-aarch_64)
			and sets the ${os.detected.classifier} property. The protobuf-maven-plugin uses
			this classifier to download the correct native protoc binary for the build host.
		-->
		<extensions>
			<extension>
				<groupId>kr.motd.maven</groupId>
				<artifactId>os-maven-plugin</artifactId>
				<version>${os-maven-plugin.version}</version>
			</extension>
		</extensions>

		<plugins>

			<!--
				Spring Boot Maven Plugin:
				Packages the application as an executable fat-jar (uber-jar) with all
				dependencies embedded. The jar can be run with: java -jar app.jar
			-->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>

			<!--
				protobuf-maven-plugin (xolstice):
				Invokes the protoc compiler at build time to generate Java source code
				from .proto files located in src/main/proto/.

				Two executions are configured:
				  1. compile         — generates Java message classes (protobuf runtime stubs).
				  2. compile-custom  — generates gRPC service stubs using the grpc-java plugin.

				Generated sources are placed in target/generated-sources/protobuf/
				and are automatically included in compilation by Maven.

				The pluginArtifact property points to the grpc-java protoc plugin binary
				that generates the abstract service base classes and blocking/async stubs.
			-->
			<plugin>
				<groupId>org.xolstice.maven.plugins</groupId>
				<artifactId>protobuf-maven-plugin</artifactId>
				<version>${protobuf-maven-plugin.version}</version>
				<configuration>
					<!--
						Download the correct protoc binary for the current OS/arch.
						${os.detected.classifier} is set by the os-maven-plugin extension above.
					-->
					<protocArtifact>
						com.google.protobuf:protoc:${protobuf.version}:exe:${os.detected.classifier}
					</protocArtifact>
					<!--
						Output directory for generated protobuf message classes.
						Maven automatically adds this directory to the compile source root.
					-->
					<outputDirectory>${project.build.directory}/generated-sources/protobuf/java</outputDirectory>
					<!--
						Clear the output directory before each generation to avoid stale files
						when .proto files are deleted or renamed.
					-->
					<clearOutputDirectory>false</clearOutputDirectory>
				</configuration>
				<executions>
					<execution>
						<id>compile-protobuf</id>
						<goals>
							<!-- Generate Java message classes from .proto files -->
							<goal>compile</goal>
							<!-- Generate gRPC service stubs using the grpc-java plugin -->
							<goal>compile-custom</goal>
						</goals>
						<configuration>
							<!--
								The grpc-java protoc plugin binary.
								Generates: abstract service base class (ImplBase), blocking stub,
								future stub, and async stub from the service definitions in .proto files.
							-->
							<pluginId>grpc-java</pluginId>
							<pluginArtifact>
								io.grpc:protoc-gen-grpc-java:${grpc.version}:exe:${os.detected.classifier}
							</pluginArtifact>
							<!--
								Output directory for generated gRPC service stubs.
								Placed alongside protobuf message classes for clarity.
							-->
							<outputDirectory>${project.build.directory}/generated-sources/protobuf/java</outputDirectory>
						</configuration>
					</execution>
				</executions>
			</plugin>

			<!--
				Maven Surefire Plugin: configures test execution for Java 21+.

				argLine breakdown:
			  -XX:+EnableDynamicAgentLoading  silences Mockito/ByteBuddy agent warnings on Java 21+
			  -Xshare:off                     disables class-data sharing (avoids rare JVM conflicts)
			  -Dnet.bytebuddy.experimental    required on Java 25+; harmless on Java 21 to 24
			  add-opens flags                 grant ByteBuddy/Mockito deep reflection access

			DOCKER_API_VERSION=1.44:
			  Docker Desktop 29+ rejects the legacy v1.24 API path used by docker-java.
			  Setting 1.44 here (and in docker-java.properties on the test classpath)
			  ensures Testcontainers works correctly on Docker Desktop 29+.
			-->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Ensures docker-java uses API v1.44 (Docker Desktop 29+ requires this) -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>

		</plugins>
	</build>

</project>
