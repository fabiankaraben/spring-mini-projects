<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>spring-cloud-gateway</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>spring-cloud-gateway</name>
	<description>Spring Boot mini-project that configures an API Gateway using Spring Cloud Gateway to route and filter HTTP requests to downstream microservices. Demonstrates predicate-based routing, pre/post filters, path rewriting, rate limiting concepts, and custom global filters.</description>

	<properties>
		<java.version>21</java.version>
		<!-- Spring Cloud BOM version aligned with Spring Boot 3.4.x -->
		<spring-cloud.version>2024.0.1</spring-cloud.version>
		<!-- Testcontainers BOM version — pins all Testcontainers module versions in sync -->
		<testcontainers.version>1.21.3</testcontainers.version>
	</properties>

	<dependencies>
		<!--
			Spring Cloud Gateway (Reactive):
			The core gateway dependency. Spring Cloud Gateway is built on top of
			Spring WebFlux (Project Reactor), which means it runs on Netty (not
			Tomcat) using a non-blocking, reactive I/O model.

			Key concepts enabled by this dependency:
			  - RouteLocator / RouteLocatorBuilder: programmatic route definitions.
			  - GatewayFilter: per-route filters (AddRequestHeader, RewritePath, etc.).
			  - GlobalFilter: filters that apply to every route automatically.
			  - Predicates: conditions that match incoming requests to routes
			    (Path, Method, Header, Query, etc.).
		-->
		<dependency>
			<groupId>org.springframework.cloud</groupId>
			<artifactId>spring-cloud-starter-gateway</artifactId>
		</dependency>

		<!--
			Spring Boot Actuator: exposes management endpoints such as
			/actuator/health, /actuator/info, and /actuator/gateway/routes.
			The /actuator/gateway/routes endpoint is especially useful — it
			shows all configured routes with their predicates and filters,
			making the gateway configuration observable at runtime.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!--
			Spring Boot Validation: provides Bean Validation (JSR-380) support
			via Hibernate Validator. Used to validate route configuration
			properties and request model objects.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!--
			Spring Boot Test: pulls in JUnit 5, AssertJ, Mockito, WebTestClient
			and all the Spring test infrastructure required for unit and
			integration tests. WebTestClient is the reactive counterpart of
			MockMvc and is used to test WebFlux-based applications.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Spring WebFlux test support: provides WebTestClient (reactive HTTP
			test client). Needed explicitly when using WebTestClient in tests
			without a full server (MOCK mode).
		-->
		<dependency>
			<groupId>io.projectreactor</groupId>
			<artifactId>reactor-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers JUnit 5 integration: provides the @Testcontainers
			class-level annotation and the @Container field annotation that
			manage Docker container lifecycle alongside the JUnit 5 test
			lifecycle.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers core module: needed for GenericContainer which lets
			us spin up downstream microservice mock containers (e.g. WireMock
			or a simple HTTP echo server) so integration tests can exercise
			real end-to-end routing through the gateway.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			WireMock standalone: the HTTP stub server used in integration tests.
			We run it inside a Docker container via Testcontainers (GenericContainer)
			rather than using the wiremock-testcontainers-module, which avoids
			platform/version compatibility issues and gives full control over the
			container configuration.
		-->
	</dependencies>

	<!--
		Manage all Spring Cloud module versions through the BOM (Bill of
		Materials). This ensures all spring-cloud-* artefacts resolve to a
		compatible set of versions, aligned with Spring Boot 3.4.x.
	-->
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.springframework.cloud</groupId>
				<artifactId>spring-cloud-dependencies</artifactId>
				<version>${spring-cloud.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
			<!-- Manage all Testcontainers module versions via the BOM so they stay in sync -->
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin: packages the application as an executable fat-jar -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>

			<!--
				Maven Surefire Plugin: configures test execution for Java 21+.

				argLine breakdown:
				  -XX:+EnableDynamicAgentLoading  - silences Mockito/ByteBuddy agent warnings
				  -Xshare:off                     - disables class-data sharing (avoids conflicts)
				  -Dnet.bytebuddy.experimental    - required on Java 25+; harmless on Java 21-24
				  add-opens                       - grants ByteBuddy/Mockito deep reflection access

				DOCKER_API_VERSION=1.44:
				  Docker Desktop 29+ rejects the legacy v1.24 API path that docker-java uses by
				  default. Setting 1.44 here (and in docker-java.properties on the test classpath)
				  ensures Testcontainers works correctly on Docker Desktop 29+.
			-->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Ensures docker-java uses API v1.44 (Docker Desktop 29+ requires this) -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>

</project>
