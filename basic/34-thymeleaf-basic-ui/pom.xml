<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.4.3</version>
        <relativePath/> <!-- lookup parent from repository -->
    </parent>
    <groupId>com.example</groupId>
    <artifactId>thymeleaf-basic-ui</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <name>thymeleaf-basic-ui</name>
    <description>Thymeleaf Basic UI mini-project: rendering dynamic HTML pages using Thymeleaf templates</description>
    <properties>
        <java.version>21</java.version>
    </properties>
    <dependencies>

        <!--
            Spring Boot Web Starter: includes Spring MVC, embedded Tomcat,
            Jackson for JSON, and all the wiring needed for @Controller endpoints.
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!--
            Thymeleaf Starter: integrates the Thymeleaf template engine with
            Spring MVC. Thymeleaf processes HTML templates stored under
            src/main/resources/templates/, replacing th:* attributes with
            dynamic values resolved from the model.
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-thymeleaf</artifactId>
        </dependency>

        <!--
            Testing: JUnit 5, Mockito, MockMvc, and Spring Boot Test utilities.
            spring-boot-starter-test transitively brings:
              - JUnit 5 (jupiter)
              - Mockito
              - Spring MockMvc
              - AssertJ
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <!-- Maven Surefire Plugin: discovers and runs unit/integration tests -->
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <!-- Required for Mockito byte-buddy on Java 21 -->
                    <argLine>-Dnet.bytebuddy.experimental=true</argLine>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
