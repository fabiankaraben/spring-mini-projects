<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.3</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.example</groupId>
	<artifactId>elastic-stack-logging</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>elastic-stack-logging</name>
	<description>
		Spring Boot mini-project demonstrating structured JSON logging shipped to the Elastic Stack
		(Elasticsearch + Logstash + Kibana). The application emits JSON-formatted log events via
		Logback + logstash-logback-encoder, which are picked up by Filebeat, forwarded through
		Logstash for enrichment, and indexed into Elasticsearch for search and visualization in
		Kibana. Includes JUnit 5 unit tests for domain logic and full integration tests with
		Testcontainers (Elasticsearch container).
	</description>

	<properties>
		<java.version>21</java.version>
		<!-- Testcontainers BOM version — pins all Testcontainers module versions in sync -->
		<testcontainers.version>1.21.3</testcontainers.version>
		<!--
			logstash-logback-encoder: Serialises Logback ILoggingEvents to JSON.
			Each log line becomes a JSON object with timestamp, level, logger,
			thread, message and any structured key/value fields added via MDC or
			StructuredArguments. Logstash/Filebeat can then parse these without
			a grok filter.
		-->
		<logstash-logback-encoder.version>8.0</logstash-logback-encoder.version>
	</properties>

	<dependencies>

		<!--
			Spring Web (MVC):
			Provides DispatcherServlet, @RestController and Jackson JSON support.
			Used to expose the Order and Product APIs that generate structured log events.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!--
			Bean Validation (Hibernate Validator):
			Provides @NotBlank, @NotNull, @Positive etc. for DTO input validation.
			Validation failures are logged as structured WARN events.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<!--
			Spring Boot Actuator:
			Exposes /actuator/health and /actuator/info endpoints.
			The health endpoint is used by Docker Compose healthcheck probes.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>

		<!--
			logstash-logback-encoder:
			Replaces Logback's default PatternLayout with a JSON encoder.

			Key features used in this project:
			  - LogstashEncoder: writes each log event as a JSON line to the file appender.
			  - StructuredArguments.kv(): adds key/value pairs directly into the JSON log
			    object (e.g., "orderId":"abc-123") — they appear as first-class JSON fields,
			    not embedded in the "message" string.
			  - MDC (Mapped Diagnostic Context): thread-local key/value bag automatically
			    included in every JSON log line within the MDC scope (used for requestId
			    and userId correlation).
		-->
		<dependency>
			<groupId>net.logstash.logback</groupId>
			<artifactId>logstash-logback-encoder</artifactId>
			<version>${logstash-logback-encoder.version}</version>
		</dependency>

		<!-- ===== Test dependencies ===== -->

		<!--
			Spring Boot Test:
			Pulls in JUnit 5, AssertJ, Mockito, MockMvc and all Spring test
			infrastructure needed for unit and integration tests.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers JUnit 5 integration:
			Provides @Testcontainers and @Container annotations that manage Docker
			container lifecycle alongside JUnit 5 test execution.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers core module:
			Provides GenericContainer used to run an Elasticsearch Docker container
			for integration tests, ensuring tests run against a real Elasticsearch instance.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>testcontainers</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Testcontainers Elasticsearch module:
			Provides ElasticsearchContainer — a convenience wrapper around
			GenericContainer that knows the correct image, port (9200) and
			wait strategy for Elasticsearch.
		-->
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>elasticsearch</artifactId>
			<scope>test</scope>
		</dependency>

		<!--
			Elasticsearch Java REST client (low-level):
			Used in integration tests to verify that log entries were correctly
			indexed into Elasticsearch. We use the low-level REST client so we
			can target any Elasticsearch version without compatibility issues.
		-->
		<dependency>
			<groupId>org.elasticsearch.client</groupId>
			<artifactId>elasticsearch-rest-client</artifactId>
			<scope>test</scope>
		</dependency>

	</dependencies>

	<!--
		Manage all Testcontainers module versions through the BOM (Bill of Materials).
		This ensures all testcontainers-* artifacts from the official org.testcontainers
		group resolve to the same compatible version set.
	-->
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.testcontainers</groupId>
				<artifactId>testcontainers-bom</artifactId>
				<version>${testcontainers.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<!-- Spring Boot Maven Plugin: packages the application as an executable fat-jar -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>

			<!--
				Maven Surefire Plugin: configures test execution for Java 21+.

				argLine breakdown:
				  -XX:+EnableDynamicAgentLoading  — silences Mockito/ByteBuddy agent warnings
				  -Xshare:off                     — disables class-data sharing (avoids conflicts)
				  -Dnet.bytebuddy.experimental    — required on Java 25+; harmless on Java 21-24
				  add-opens                       — grants ByteBuddy/Mockito deep reflection access

				DOCKER_API_VERSION=1.44:
				  Docker Desktop 29+ rejects the legacy v1.24 API path that docker-java uses by
				  default. Setting 1.44 here (and in docker-java.properties on the test classpath)
				  ensures Testcontainers works correctly on Docker Desktop 29+.
			-->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-XX:+EnableDynamicAgentLoading -Xshare:off -Dnet.bytebuddy.experimental=true --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED</argLine>
					<environmentVariables>
						<!-- Ensures docker-java uses API v1.44 (Docker Desktop 29+ requires this) -->
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</environmentVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>

</project>
